$ORIGIN cloud.local.
@       3600 IN SOA sns.dns.icann.org. noc.dns.icann.org. (
                                2017042745 ; serial
                                7200       ; refresh (2 hours)
                                3600       ; retry (1 hour)
                                1209600    ; expire (2 weeks)
                                3600       ; minimum (1 hour)
                                )

        3600 IN NS a.iana-servers.net.
        3600 IN NS b.iana-servers.net.

; Bản ghi các service
web-frontend-server.cloud.local.    IN A 10.10.10.10
app-backend.cloud.local.            IN A 10.10.10.20
minio.cloud.local.                  IN A 10.10.10.30
keycloak.cloud.local.               IN A 10.10.10.40

; Bản ghi m-* (tùy chọn)
m-web.cloud.local.                  IN A 172.24.0.11
m-app.cloud.local.                  IN A 172.24.0.9
m-db.cloud.local.                   IN A 172.24.0.3
