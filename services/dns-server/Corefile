.:53 {
    # Logging all requests
    log
    # Errors to stdout
    errors

    # Use zone file for cloud.local
    file /etc/coredns/db.cloud.local cloud.local

    # DNS Proxy for everything else (internet)
    forward . 8.8.8.8 8.8.4.4

    # Buffer cache
    cache 30

    # Enable metrics for prometheus scraping
    prometheus :9153
}
